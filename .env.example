# =============================================================================
# Automated Lithology Classification System - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit the .env file to version control.

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Lithology Classification System
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/lithology_db
DATABASE_URL_SYNC=postgresql://postgres:password@db:5432/lithology_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=lithology_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Test Database
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lithology_test_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
REDIS_MAX_CONNECTIONS=10
CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MODEL_DIR=./model_weights
MAX_UPLOAD_SIZE_MB=50
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,tiff,bmp
ALLOWED_DATASET_EXTENSIONS=zip,tar,tar.gz

# -----------------------------------------------------------------------------
# ML Models
# -----------------------------------------------------------------------------
MODEL_DIR=./model_weights
PRIMARY_MODEL=efficientnet_b3
SECONDARY_MODEL=resnet50
EFFICIENTNET_WEIGHTS_PATH=./model_weights/efficientnet_b3.pth
RESNET_WEIGHTS_PATH=./model_weights/resnet50.pth
NUM_CLASSES=10
IMAGE_SIZE=300
BATCH_SIZE=32
CONFIDENCE_THRESHOLD=0.75
ENSEMBLE_WEIGHTS=0.6,0.4

# Lithology Classes (comma-separated in order)
LITHOLOGY_CLASSES=Sandstone,Shale,Limestone,Granite,Basalt,Quartzite,Mudstone,Dolomite,Conglomerate,Coal

# -----------------------------------------------------------------------------
# LLM & RAG Configuration
# -----------------------------------------------------------------------------
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=./faiss_index
KNOWLEDGE_BASE_DIR=./knowledge_base
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
RAG_TOP_K=5
USE_GPU=false

# Hugging Face (optional for gated models)
HUGGINGFACE_TOKEN=hf_your_token_here

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo

# -----------------------------------------------------------------------------
# CORS & Networking
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=*
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Celery Task Queue
# -----------------------------------------------------------------------------
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000
CELERY_WORKER_CONCURRENCY=4
CELERY_BEAT_SCHEDULE_INTERVAL=60

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@lithology.ai
EMAILS_ENABLED=false

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:80/api/v1
VITE_APP_NAME=Lithology AI
VITE_APP_VERSION=1.0.0
